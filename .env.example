# Copy to ".env" in the project root for docker compose variable substitution and local tools.
# Docker Compose loads this file automatically when present (same directory as docker-compose.yml).

# Required for any non-dev deployment; compose default is insecure.
SECRET_KEY=change-me-to-a-long-random-string

DEBUG=True

# Comma-separated hosts (no spaces). Use * only in development.
ALLOWED_HOSTS=localhost,127.0.0.1

# Comma-separated origins for CSRF (include scheme and port).
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,https://markethub.up.railway.app

# PostgreSQL (Docker service name "db", internal port 5432). Uncomment for dockerized stack.
# DATABASE_URL=postgresql://marketinghub:marketinghub@db:5432/marketinghub

# Set to true only if your managed Postgres requires TLS (not typical for docker-compose internal db).
# DATABASE_SSL_REQUIRE=false

# Redis: when set, Django uses Redis for cache and session store (good for multi-worker Gunicorn).
# Docker Compose sets this for the web service by default. Omit for local SQLite dev without Redis.
# REDIS_URL=redis://127.0.0.1:6379/0

# Gunicorn
PORT=8000
# GUNICORN_WORKERS=2
